{
  "name": "web",
  "version": "0.23.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "generate:catalog": "node scripts/generate-catalog-assets.mjs",
    "generate:process-image": "npm run generate:process-images",
    "generate:process-images": "node scripts/generate-process-article-image.mjs",
    "generate:verification-queue": "node scripts/generate-field-verification-queue.mjs",
    "check:freshness": "node scripts/sync-verification.mjs --check",
    "predev": "npm run generate:catalog && npm run generate:verification-queue && npm run generate:process-images && npm run generate:routing-index && npm run generate:summaries && npm run generate:build-stamp",
    "dev": "next dev",
    "prebuild": "npm run generate:catalog && npm run generate:verification-queue && npm run generate:process-images && npm run generate:routing-index && npm run generate:summaries && npm run generate:build-stamp",
    "start": "next start",
    "lint": "eslint",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:process-images": "node scripts/validate-process-images.mjs",
    "sync:sources": "node scripts/sync-verification.mjs",
    "verify:articles": "node scripts/verify-articles.mjs",
    "test:article-parser": "node --test scripts/article-citations.test.mjs",
    "test:process-layout": "node --test scripts/process-layout.test.mjs",
    "verify:citation-content": "node scripts/verify-citation-content.mjs",
    "generate:routing-index": "node scripts/generate-routing-index.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:summaries": "node scripts/generate-summaries.mjs",
    "generate:build-stamp": "node scripts/generate-build-stamp.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/genai": "^2.12.0",
    "next": "16.2.10",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
